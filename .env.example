# Copy to .env and fill in. Optional: use scoped names (UAT_, STAGE_, PROD_) when
# all three blocks live in one file; otherwise unscoped names apply to any selected env.

# Server
PORT=3000

# --- Shared (used if scoped var not set) ---
POSTGRES_LABEL=PostgreSQL
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DATABASE=postgres

CASSANDRA_LABEL=Cassandra
CASSANDRA_CONTACT_POINTS=127.0.0.1
CASSANDRA_LOCAL_DATA_CENTER=datacenter1
CASSANDRA_KEYSPACE=system
# CASSANDRA_USERNAME=
# CASSANDRA_PASSWORD=

MONGODB_LABEL=MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=test

# --- Per-environment overrides (examples) ---
# UAT_POSTGRES_HOST=...
# STAGE_POSTGRES_HOST=...
# PROD_POSTGRES_PASSWORD=...
